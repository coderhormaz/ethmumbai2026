# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Ethereum L1 Sepolia (for ENS resolution) ────────────────
# Get a free key at https://www.alchemy.com or https://www.infura.io
L1_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"

# ── Base Sepolia (x402 payments) ────────────────────────────
BASE_SEPOLIA_RPC_URL="https://base-sepolia-rpc.publicnode.com"
USDC_ADDRESS_BASE_SEPOLIA="0x036CbD53842c5426634e7929541eC2318f3dCF7e"

# ── AI Provider ─────────────────────────────────────────────
# OpenRouter key (works with Claude, GPT, Gemini, Grok, etc.)
AI_PROVIDER_API_KEY="sk-or-v1-YOUR-OPENROUTER-KEY"
AI_PROVIDER_URL="https://openrouter.ai/api/v1/chat/completions"
# Optional: force a single upstream model for demos. Leave empty for normal behavior.
DEMO_UPSTREAM_MODEL=""

# ── Seller Identity ─────────────────────────────────────────
# Your ENS subname (e.g., claude-proxy.abdul.eth)
PROXY_SELLER_ENS="claude-proxy.yourname.eth"

# ── Fallback (used when ENS text records aren't set yet) ────
FALLBACK_MODELS="claude-3.5-sonnet,gpt-4o,grok-beta,gemini-pro"
FALLBACK_PRICE_INPUT="0.0008"
FALLBACK_PRICE_OUTPUT="0.0024"
FALLBACK_RECIPIENT="0xYOUR_WALLET_ADDRESS"

# ── Testing ─────────────────────────────────────────────────
# Private key of a funded Base Sepolia wallet (for test client)
TESTER_PRIVATE_KEY=""
